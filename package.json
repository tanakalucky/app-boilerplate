{
  "name": "app-boilerplate",
  "version": "0.0.0",
  "description": "A template for building a React application with Vite",
  "type": "module",
  "scripts": {
    "build": "vite build",
    "cf-typegen": "wrangler types",
    "check": "bun typecheck && bun run build && wrangler deploy --dry-run",
    "claude:copy": "bun run scripts/copy-claude-config.ts",
    "deploy": "wrangler deploy",
    "dev": "dotenvx run -f .env.dev -- vite",
    "format": "oxfmt .",
    "lint": "oxlint --type-aware --fix",
    "lint:ci": "oxlint --type-aware",
    "preview": "dotenvx run -f .env.dev -- bun run build && vite preview",
    "test": "vitest --project unit & vitest --project browser & dotenvx run -f .env.dev -- bun run playwright test",
    "typecheck": "bun tsgo -b --noEmit",
    "ui:add": "bun run scripts/shadcn-add.ts",
    "ui:organize": "bun run scripts/organize-ui.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@clerk/react": "^6.4.3",
    "@fontsource-variable/noto-sans": "^5.2.10",
    "@tailwindcss/vite": "^4.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "convex": "^1.36.1",
    "lucide-react": "^1.11.0",
    "next-themes": "^0.4.6",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-error-boundary": "^6.1.1",
    "shadcn": "^4.4.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.4",
    "ts-pattern": "^5.9.0",
    "valibot": "^1.3.1",
    "wouter": "^3.9.0"
  },
  "devDependencies": {
    "@clerk/testing": "^2.0.21",
    "@cloudflare/vite-plugin": "^1.33.2",
    "@dotenvx/dotenvx": "^1.63.0",
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@typescript/native-preview": "^7.0.0-dev.20260424.2",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/browser-playwright": "^4.1.5",
    "@vitest/ui": "^4.1.5",
    "eslint-plugin-better-tailwindcss": "^4.4.1",
    "lefthook": "^2.1.6",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "oxlint-tsgolint": "^0.21.1",
    "playwright": "^1.59.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "6.0.3",
    "vite": "8.0.10",
    "vitest": "^4.1.5",
    "vitest-browser-react": "^2.2.0",
    "wrangler": "^4.85.0"
  },
  "cloudflare": {
    "label": "App Boilerplate",
    "products": [
      "Workers"
    ],
    "categories": [],
    "icon_urls": [
      "https://imagedelivery.net/wSMYJvS3Xw-n339CbDyDIA/5ca0ca32-e897-4699-d4c1-6b680512f000/public"
    ],
    "preview_image_url": "https://imagedelivery.net/wSMYJvS3Xw-n339CbDyDIA/fc7b4b62-442b-4769-641b-ad4422d74300/public",
    "publish": true
  }
}
